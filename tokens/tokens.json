{
  "$schema": "https://dzarlax.dev/design-system/tokens.schema.json",
  "description": "Canonical source for dzarlax design system tokens. Edit this file, then run `python3 bin/gen-tokens.py` (or `./build.sh`, which calls it). The generator emits tokens/colors.css, themes/dark.css, and tokens/ios/DesignSystemColors.swift — do not hand-edit those.",
  "color": {
    "brand": {
      "dark":  { "light": "#2B2B2B", "dark": "#2B2B2B" },
      "light": { "light": "#F5F0E8", "dark": "#F5F0E8" }
    },
    "bg":         { "light": "#FCFAF7", "dark": "#1A1D21" },
    "surface":    { "light": "#FFFFFF", "dark": "#22252A" },
    "surface-2":  { "light": "#E8E6E3", "dark": "#2A2D32" },
    "surface-3":  { "light": "#DCDAD7", "dark": "#33363B", "note": "Elevated/modal surface, mostly used on mobile" },
    "text":               { "light": "#1A1A1E", "dark": "#F5F5F5" },
    "text-secondary":     { "light": "rgba(26,26,30,0.7)",  "dark": "rgba(245,245,245,0.7)" },
    "text-tertiary":      { "light": "rgba(26,26,30,0.5)",  "dark": "rgba(245,245,245,0.5)" },
    "accent":             { "light": "#18181B", "dark": "#F5F5F5" },
    "accent-hover":       { "light": "#25282D", "dark": "#E0E0E0" },
    "accent-foreground":  { "light": "#FFFFFF", "dark": "#1A1A1E", "note": "Foreground that reads on accent (button labels, etc.)" },
    "border":         { "light": "rgba(0,0,0,0.08)", "dark": "rgba(255,255,255,0.08)" },
    "border-hover":   { "light": "rgba(0,0,0,0.12)", "dark": "rgba(255,255,255,0.12)" },
    "border-light":   { "light": "rgba(26,26,30,0.04)", "dark": "rgba(255,255,255,0.05)" },
    "good":      { "light": "#16a34a", "dark": "#22c55e" },
    "good-bg":   { "light": "#f0fdf4", "dark": "rgba(22,163,74,0.15)" },
    "warn":      { "light": "#d97706", "dark": "#f59e0b" },
    "warn-bg":   { "light": "#fffbeb", "dark": "rgba(217,119,6,0.15)" },
    "danger":    { "light": "#dc2626", "dark": "#ef4444" },
    "danger-bg": { "light": "#fef2f2", "dark": "rgba(220,38,38,0.15)" },
    "heart":     { "light": "#e11d48", "dark": "#fb7185" },
    "activity":  { "light": "#059669", "dark": "#34d399" },
    "sleep":     { "light": "#7c3aed", "dark": "#a78bfa" },
    "cardio":    { "light": "#0284c7", "dark": "#38bdf8" }
  },
  "radius": {
    "sm": "4px",
    "default": "8px",
    "lg": "12px"
  },
  "shadow": {
    "sm":      { "light": "0 1px 2px 0 rgba(0, 0, 0, 0.04)",     "dark": "0 1px 2px 0 rgba(0, 0, 0, 0.15)" },
    "default": { "light": "0 4px 6px -1px rgba(0, 0, 0, 0.07)",  "dark": "0 4px 6px -1px rgba(0, 0, 0, 0.3)" },
    "lg":      { "light": "0 8px 30px rgba(0, 0, 0, 0.08)",      "dark": "0 8px 30px rgba(0, 0, 0, 0.4)" },
    "xl":      { "light": "0 20px 25px -5px rgba(0, 0, 0, 0.08)", "dark": "0 20px 25px -5px rgba(0, 0, 0, 0.4)" }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "default": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "typography": {
    "heading-family": "Georgia, serif",
    "body-family": "system-ui, -apple-system, sans-serif",
    "size": {
      "title":    "28px",
      "heading":  "20px",
      "subhead":  "17px",
      "body":     "16px",
      "body-sm":  "14px",
      "caption":  "12px"
    }
  }
}
